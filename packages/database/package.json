{
  "name": "@mensah-rentals/database",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.json",
    "typecheck": "pnpm db:generate && tsc -p tsconfig.json --noEmit",
    "test": "dotenv -e ../../.env -- vitest run",
    "db:validate": "dotenv -e ../../.env -- prisma validate --schema=prisma/schema.prisma",
    "db:generate": "dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy --schema=prisma/schema.prisma",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:status": "dotenv -e ../../.env -- prisma migrate status --schema=prisma/schema.prisma",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --schema=prisma/schema.prisma",
    "staff:bootstrap": "dotenv -e ../../.env -- node dist/scripts/bootstrap-staff.js",
    "rbac:seed": "dotenv -e ../../.env -- node dist/scripts/seed-rbac.js",
    "rbac:verify": "dotenv -e ../../.env -- node dist/scripts/verify-rbac.js",
    "catalogue:seed": "dotenv -e ../../.env -- node dist/scripts/seed-catalogue.js"
  },
  "dependencies": {
    "@mensah-rentals/auth": "workspace:*",
    "@mensah-rentals/rbac": "workspace:*",
    "@mensah-rentals/validation": "workspace:*",
    "@prisma/client": "6.15.0"
  },
  "devDependencies": {
    "@mensah-rentals/config": "workspace:*",
    "@types/node": "22.18.1",
    "dotenv-cli": "10.0.0",
    "prisma": "6.15.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
