# Local development only. Replace these values for staging and production.
NODE_ENV=development
POSTGRES_USER=mensah_dev
POSTGRES_PASSWORD=mensah_dev_password
POSTGRES_DB=mensah_rentals_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mensah_dev:mensah_dev_password@localhost:5432/mensah_rentals_dev?schema=public

API_PORT=4000
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001
API_INTERNAL_URL=http://localhost:4000

# Staff authentication. Keep Secure=false only for HTTP localhost development.
STAFF_SESSION_COOKIE_NAME=mensah_staff_session
STAFF_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW_SECONDS=60

# Used only by `pnpm staff:bootstrap` in NODE_ENV=development.
# Set these values in the ignored .env file; never commit a real password.
STAFF_BOOTSTRAP_EMAIL=
STAFF_BOOTSTRAP_PASSWORD=
STAFF_BOOTSTRAP_FIRST_NAME=
STAFF_BOOTSTRAP_LAST_NAME=
