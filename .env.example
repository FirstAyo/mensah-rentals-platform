# Local development only. Replace these values for staging and production.
NODE_ENV=development
POSTGRES_USER=mensah_dev
POSTGRES_PASSWORD=mensah_dev_password
POSTGRES_DB=mensah_rentals_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mensah_dev:mensah_dev_password@localhost:5432/mensah_rentals_dev?schema=public

API_PORT=4000
WEB_ORIGIN=http://localhost:3000
SITE_INDEXING_ENABLED=false
ADMIN_ORIGIN=http://localhost:3001
API_INTERNAL_URL=http://localhost:4000
MEDIA_STORAGE_ROOT=storage/media

# Anonymous customer rental cart. Keep Secure=false only for HTTP localhost.
PUBLIC_CART_COOKIE_NAME=mensah_rental_cart
PUBLIC_CART_TTL_DAYS=30
PUBLIC_CART_COOKIE_SECURE=false

# Guest rental-request tracking. The development secret is not suitable for production.
PUBLIC_REQUEST_COOKIE_NAME=mensah_rental_request
PUBLIC_REQUEST_COOKIE_SECURE=false
PUBLIC_REQUEST_TRACKING_TTL_DAYS=180
PUBLIC_REQUEST_TRACKING_SECRET=development-only-change-this-tracking-secret
PUBLIC_REQUEST_SUBMIT_RATE_LIMIT=5
PUBLIC_REQUEST_SUBMIT_RATE_WINDOW_SECONDS=3600
PUBLIC_REQUEST_TRACK_RATE_LIMIT=60
PUBLIC_REQUEST_TRACK_RATE_WINDOW_SECONDS=60
PUBLIC_REQUEST_GLOBAL_RATE_LIMIT=10000
PUBLIC_REQUEST_GLOBAL_RATE_WINDOW_SECONDS=60

# Staff authentication. Keep Secure=false only for HTTP localhost development.
STAFF_SESSION_COOKIE_NAME=mensah_staff_session
STAFF_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW_SECONDS=60

# Used only by `pnpm staff:bootstrap` in NODE_ENV=development.
# Set these values in the ignored .env file; never commit a real password.
STAFF_BOOTSTRAP_EMAIL=
STAFF_BOOTSTRAP_PASSWORD=
STAFF_BOOTSTRAP_FIRST_NAME=
STAFF_BOOTSTRAP_LAST_NAME=
